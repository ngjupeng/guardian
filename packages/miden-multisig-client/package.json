{
  "name": "@openzeppelin/miden-multisig-client",
  "version": "0.13.4",
  "description": "TypeScript SDK for Miden multisig accounts with GUARDIAN integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "masm"
  ],
  "scripts": {
    "generate:masm": "node ./scripts/generate-masm.mjs",
    "build": "npm run generate:masm && tsc",
    "dev": "npm run generate:masm && tsc --watch",
    "typecheck": "npm run generate:masm && tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run generate:masm && vitest run",
    "test:watch": "npm run generate:masm && vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@miden-sdk/miden-sdk": "0.13.0",
    "@noble/hashes": "^2.0.1",
    "@openzeppelin/guardian-client": "^0.13.4"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}

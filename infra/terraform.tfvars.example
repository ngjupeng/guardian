# Required: AWS region
aws_region = "us-east-1"

# Optional: ECS/image architecture
# cpu_architecture = "X86_64"
# cpu_architecture = "ARM64"

# Optional: Base stack name used to derive AWS resource names
# stack_name = "guardian"
# stack_name = "psm"

# Required: ECR image URI for the server image
# After pushing to ECR, set this to the full image URI
server_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/guardian-server:latest"

# Optional: Miden network for the deployed GUARDIAN server
# server_network_type = "MidenTestnet"

# Optional: VPC and subnet configuration
# If not specified, uses the default VPC and all its subnets
# vpc_id     = "vpc-xxxxxxxx"
# subnet_ids = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]

# Optional: Postgres credentials
# Defaults derive from stack_name when omitted
# postgres_db       = "guardian"
# postgres_user     = "guardian"
# postgres_password = "guardian_dev_password"

# Optional: Managed RDS sizing
# rds_instance_class = "db.t3.micro"
# rds_allocated_storage = 20

# Optional: Route 53 hosted zone ID (auto-lookup by domain name)
# route53_zone_id = "Z1234567890ABC"

# Optional: Restrict ALB ingress (defaults to 0.0.0.0/0)
# alb_ingress_cidrs = ["203.0.113.0/24"]

# Optional: CloudWatch log retention
# log_retention_days = 7

# Optional: Task resource configuration
# server_cpu    = 512
# server_memory = 1024

# Optional: Resource naming (defaults match the original bash script)
# cluster_name                 = "guardian-cluster"
# server_service_name          = "guardian-server"
# alb_name                     = "guardian-alb"
# target_group_name            = "guardian-server-tg"
# alb_security_group_name      = "guardian-alb-sg"
# server_security_group_name   = "guardian-server-sg"
# postgres_security_group_name = "guardian-postgres-sg"
# task_execution_role_name     = "guardian-ecs-task-execution"
# task_role_name               = "guardian-ecs-task"
# server_task_family           = "guardian-server"
# server_container_name        = "guardian-server"
# server_log_group_name        = "/ecs/guardian-server"
